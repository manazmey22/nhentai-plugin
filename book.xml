<?xml version="1.0" encoding="utf-8"?>
<Scaffold>
  <attr:appBar>
    <AppBar elevation="0" title="nhentai">
      <attr:actions>
        <IconButton
          icon="favorite"
          onPressed="toggleFavorite()"/>
      </attr:actions>
    </AppBar>
  </attr:appBar>

  <if candidate="${loading}">
    <Center>
      <CircularProgressIndicator/>
    </Center>
  </if>

  <if candidate="${not(loading)}">
    <SingleChildScrollView>
      <Column>

        <!-- Обложка -->
        <Padding>
          <attr:padding><EdgeInsets all="12"/></attr:padding>
          <Row crossAxisAlignment="start">
            <ClipRRect borderRadius="8">
              <Image.network width="130" height="185" fit="cover">
                $cover
              </Image.network>
            </ClipRRect>
            <SizedBox width="12"/>
            <Expanded>
              <Column crossAxisAlignment="start">
                <if candidate="${detail}">
                  <Text maxLines="4" overflow="ellipsis">${detail.titlePretty}</Text>
                  <SizedBox height="6"/>
                  <Text>${detail.pages} pages</Text>
                  <SizedBox height="2"/>
                  <Text>${detail.favorites} favorites</Text>
                </if>
              </Column>
            </Expanded>
          </Row>
        </Padding>

        <Divider/>

        <!-- Теги -->
        <if candidate="${detail}">
          <Padding>
            <attr:padding><EdgeInsets all="12"/></attr:padding>
            <Column crossAxisAlignment="start">

              <if candidate="${not(equal(0, detail.artists.length))}">
                <Text style="caption">Artists</Text>
                <SizedBox height="4"/>
                <Wrap spacing="4" runSpacing="4">
                  <for array="$detail.artists">
                    <Chip label="$item"/>
                  </for>
                </Wrap>
                <SizedBox height="8"/>
              </if>

              <if candidate="${not(equal(0, detail.parodies.length))}">
                <Text style="caption">Parodies</Text>
                <SizedBox height="4"/>
                <Wrap spacing="4" runSpacing="4">
                  <for array="$detail.parodies">
                    <Chip label="$item"/>
                  </for>
                </Wrap>
                <SizedBox height="8"/>
              </if>

              <if candidate="${not(equal(0, detail.characters.length))}">
                <Text style="caption">Characters</Text>
                <SizedBox height="4"/>
                <Wrap spacing="4" runSpacing="4">
                  <for array="$detail.characters">
                    <Chip label="$item"/>
                  </for>
                </Wrap>
                <SizedBox height="8"/>
              </if>

              <if candidate="${not(equal(0, detail.tags.length))}">
                <Text style="caption">Tags</Text>
                <SizedBox height="4"/>
                <Wrap spacing="4" runSpacing="4">
                  <for array="$detail.tags">
                    <Chip label="$item"/>
                  </for>
                </Wrap>
                <SizedBox height="8"/>
              </if>

              <if candidate="${not(equal(0, detail.languages.length))}">
                <Text style="caption">Languages</Text>
                <SizedBox height="4"/>
                <Wrap spacing="4" runSpacing="4">
                  <for array="$detail.languages">
                    <Chip label="$item"/>
                  </for>
                </Wrap>
              </if>

            </Column>
          </Padding>
        </if>

        <Divider/>

        <!-- Кнопка читать -->
        <Padding>
          <attr:padding><EdgeInsets all="16"/></attr:padding>
          <ElevatedButton onPressed="readNow()">
            <Text>Read Now</Text>
          </ElevatedButton>
        </Padding>

      </Column>
    </SingleChildScrollView>
  </if>

</Scaffold>
